# Porta HTTP (Railway define automaticamente)
PORT=8081

# Mercado Pago — credenciais de produção
MERCADOPAGO_ACCESS_TOKEN=APP_USR-xxxx
MERCADOPAGO_PUBLIC_KEY=APP_USR-xxxx
# Secret usado para validar a assinatura HMAC dos webhooks
# (Painel MP > Suas integrações > Notificações > Webhooks > Segredo)
MERCADOPAGO_WEBHOOK_SECRET=

# WhatsApp suporte (opcional, exposto em /api/checkout/config)
WHATSAPP_SUPPORT_NUMBER=

# CORS — lista separada por vírgula com as origens permitidas em produção.
# Vazio = libera todas (apenas dev). Em produção, defina os domínios da Vercel.
# Exemplo: CORS_ALLOWED_ORIGINS=https://dnmaria.com.br,https://www.dnmaria.com.br
CORS_ALLOWED_ORIGINS=

# Logs
LOG_LEVEL=info
NODE_ENV=production
